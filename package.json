    "countries-list": "^3.1.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "inngest": "^4.1.0",
    "lucide-react": "^0.383.0",
    "next": "14.2.35",
    "posthog-js": "^1.364.1",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.9.4",
    "stripe": "^21.0.1",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8"
