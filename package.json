    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "agora-access-token": "^2.0.4",
    "agora-rtc-sdk-ng": "^4.24.3",
    "clsx": "^2.1.1",
