# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional (new key format): use this instead of SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SECRET_KEY=your-supabase-secret-key
# Supabase Postgres direct SQL clients (do NOT use direct URL in serverless runtime)
# Pooled URL (Supavisor transaction mode) for app runtime and server actions that use direct SQL clients.
# Must be port 6543 in production.
SUPABASE_DB_POOLER_URL=postgresql://postgres.your-project:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# Optional direct URL for migrations/maintenance only (typically port 5432).
SUPABASE_DB_DIRECT_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres?sslmode=require
# Optional aliases expected by some tooling:
DATABASE_URL=postgresql://postgres.your-project:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_DIRECT_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres?sslmode=require

# App
# Canonical app URL used in server redirects and links
APP_BASE_URL=http://localhost:3000
# Public URL used by frontend/client side
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Primary domain host (no protocol), used for CORS defaults
APP_PRIMARY_DOMAIN=muuday.com
# Extra CORS origins for all API routes (comma separated)
API_CORS_ORIGINS=http://localhost:3000
# Extra CORS origins for waitlist endpoint (comma separated)
WAITLIST_CORS_ORIGINS=http://localhost:3000
# Browser origins allowed for webhook endpoints (comma separated, optional)
# Leave empty to allow only non-browser server-to-server calls.
WEBHOOK_CORS_ORIGINS=
# Secret used by Supabase Database Webhooks -> /api/webhooks/supabase-db
SUPABASE_DB_WEBHOOK_SECRET=your-long-random-db-webhook-secret
CRON_SECRET=your-long-random-cron-secret
# Optional: set true to fail admin actions when audit-log write fails
ADMIN_AUDIT_FAIL_ON_ERROR=false

# Resend (email)
RESEND_API_KEY=re_your_resend_api_key

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Sentry (observability)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog (product analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Stripe (payments, billing, payouts)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_... (set after creating webhook endpoint)
# STRIPE_CONNECT_CLIENT_ID=ca_... (set after enabling Connect)
# BR account (dual-platform)
STRIPE_BR_SECRET_KEY=
NEXT_PUBLIC_STRIPE_BR_PUBLISHABLE_KEY=
# STRIPE_BR_WEBHOOK_SECRET=whsec_...
# Optional plan price IDs per region/cycle
STRIPE_PRICE_PROFESSIONAL_MONTHLY_UK=
STRIPE_PRICE_PROFESSIONAL_ANNUAL_UK=
STRIPE_PRICE_PREMIUM_MONTHLY_UK=
STRIPE_PRICE_PREMIUM_ANNUAL_UK=
STRIPE_PRICE_PROFESSIONAL_MONTHLY_BR=
STRIPE_PRICE_PROFESSIONAL_ANNUAL_BR=
STRIPE_PRICE_PREMIUM_MONTHLY_BR=
STRIPE_PRICE_PREMIUM_ANNUAL_BR=

# Agora (video sessions)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Calendar sync providers (OAuth / CalDAV support)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
CALENDAR_TOKEN_ENCRYPTION_KEY=your-32-byte-key-base64
CALENDAR_OAUTH_STATE_SECRET=your-long-random-state-secret

# Inngest (background job orchestration)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Supabase Auth smoke validation (optional)
SUPABASE_AUTH_TEST_EMAIL=

# E2E / Playwright smoke tests (quality expansion)
E2E_BASE_URL=https://muuday-app.vercel.app
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
E2E_PROFESSIONAL_EMAIL=
E2E_PROFESSIONAL_PASSWORD=
E2E_PROFESSIONAL_ID=
# Optional: dedicated professional in manual confirmation mode
E2E_MANUAL_PROFESSIONAL_ID=
# Optional: dedicated professional with first-booking gate blocked
E2E_BLOCKED_PROFESSIONAL_ID=

# Optional RLS direct API audit overrides (fallbacks to E2E credentials above)
RLS_A_EMAIL=
RLS_A_PASSWORD=
RLS_B_EMAIL=
RLS_B_PASSWORD=
# Optional explicit sample row IDs (use when auto-discovery finds no rows)
RLS_SAMPLE_BOOKING_ID=
RLS_SAMPLE_PAYMENT_ID=
RLS_SAMPLE_HIDDEN_REVIEW_ID=
RLS_SAMPLE_MESSAGE_ID=
