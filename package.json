  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "inngest:dev": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "test:e2e": "playwright test",
    "test:unit": "npm run test:state-machines",
    "test:state-machines": "node scripts/ops/test-state-machines.cjs",
