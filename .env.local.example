# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional (new key format): use this instead of SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SECRET_KEY=your-supabase-secret-key

# App
# Canonical app URL used in server redirects and links
APP_BASE_URL=http://localhost:3000
# Public URL used by frontend/client side
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Primary domain host (no protocol), used for CORS defaults
APP_PRIMARY_DOMAIN=muuday.com
# Extra CORS origins for waitlist endpoint (comma separated)
WAITLIST_CORS_ORIGINS=http://localhost:3000
CRON_SECRET=your-long-random-cron-secret

# Resend (email)
RESEND_API_KEY=re_your_resend_api_key

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
