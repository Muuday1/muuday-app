# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional (new key format): use this instead of SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SECRET_KEY=your-supabase-secret-key

# App
# Canonical app URL used in server redirects and links
APP_BASE_URL=http://localhost:3000
# Public URL used by frontend/client side
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Primary domain host (no protocol), used for CORS defaults
APP_PRIMARY_DOMAIN=muuday.com
# Extra CORS origins for waitlist endpoint (comma separated)
WAITLIST_CORS_ORIGINS=http://localhost:3000
CRON_SECRET=your-long-random-cron-secret

# Resend (email)
RESEND_API_KEY=re_your_resend_api_key

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Sentry (observability)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog (product analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Inngest (background job orchestration)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Supabase Auth smoke validation (optional)
SUPABASE_AUTH_TEST_EMAIL=

# E2E / Playwright smoke tests (quality expansion)
E2E_BASE_URL=https://muuday-app.vercel.app
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
E2E_PROFESSIONAL_ID=
# Optional: dedicated professional in manual confirmation mode
E2E_MANUAL_PROFESSIONAL_ID=
