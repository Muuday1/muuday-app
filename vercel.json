{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "functions": {
    "app/api/webhooks/**/*.ts": {
      "maxDuration": 60
    },
    "app/api/cron/**/*.ts": {
      "maxDuration": 60
    },
    "app/api/stripe/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/booking-timeouts",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/booking-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/public-visibility-sync",
      "schedule": "*/15 * * * *"
    }
  ]
}
