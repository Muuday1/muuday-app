    "test:checkly-local": "playwright test --config playwright.checkly.config.ts",
    "fixtures:ensure-public-ready": "node scripts/ops/ensure-test-professionals-public-ready.cjs",
    "checkly:validate": "checkly debug parse-project --config checkly.config.js",
    "checkly:test": "checkly test",
    "checkly:deploy": "checkly deploy",
    "checkly:plan": "checkly account plan --output json",
    "check:encoding": "node scripts/ops/check-mojibake.cjs",
    "test:smoke": "python scripts/smoke_test.py",
    "test:unit:watch": "vitest",
    "db:gen-types": "npx supabase gen types typescript --project-id jbbnbbrroifghrshplsq --schema public > types/supabase-generated.ts"
  },
