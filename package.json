  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "inngest:dev": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/api-v1-smoke.spec.ts",
    "test:unit": "vitest run",
    "test:state-machines": "node scripts/ops/test-state-machines.cjs",
    "db:validate-pooling": "node scripts/ops/validate-db-pooling-config.cjs",
    "audit:auth-role-claims": "node scripts/ops/audit-role-claim-coverage.cjs",
    "audit:rls:api": "node scripts/ops/audit-rls-direct-api.cjs",
    "secrets:rotation:check": "node scripts/ops/check-secrets-rotation.cjs",
    "secrets:rotation:stamp": "node scripts/ops/stamp-secrets-rotation.cjs",
    "secrets:sync:audit": "node scripts/ops/audit-secrets-sync.cjs",
    "secrets:rotate:auto": "node scripts/ops/rotate-secrets.cjs",
    "secrets:rotate:auto:dry": "node scripts/ops/rotate-secrets.cjs --dry-run",
    "secrets:env:audit": "node scripts/ops/audit-env-local-vs-vercel.cjs",
